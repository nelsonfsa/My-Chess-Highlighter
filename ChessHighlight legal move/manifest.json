{
  "manifest_version": 3,
  "name": "My Chess Highlighter",
  "version": "1.0",
  "description": "Custom legal move square highlights for chess.com",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.chess.com/*"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ]
}